      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "viem": "^2.21.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun run build.ts --watch",
    "clean": "rm -rf dist",
    "test": "bun test"
  }
}
